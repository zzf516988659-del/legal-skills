.DS_Store
.specstory/
.vscode/
*.code-workspace
dist/
/references/
!skills/*/references/
test/
templates/
!skills/*/templates/
# Claude Code config - selective sync (keep skills symlink, ignore rest)
.claude/commands/
.claude/plans/
.claude/*.json
!.claude/settings.local.json
**/DECISIONS.md
**/TASKS.md
!CLAUDE.md
**/*/CLAUDE.md

# project-init 参考文件：这些是模板，不是运行时生成的项目文件
!skills/project-init/references/DECISIONS.md
!skills/project-init/references/CLAUDE.md

# Archive directories - ignore content but keep directory structure
**/archive/*
!**/archive/.gitkeep
/archive/

# Environment files - ignore all .env files to prevent credential leaks
# Use .env.example for templates
**/.env
!**/.env.example
**/config/*.yaml
!**/config/*.example.yaml
**/config/*.json
!**/config/*.example.json
# Team config - keep example, ignore real data and images
skills/legal-proposal-generator/config/team-config.md
skills/legal-proposal-generator/config/images/

# User profile - ignore personal data but keep example
**/reference/user-profile.md
!**/reference/user-profile.example.md
.history/

# Node.js dependencies
**/node_modules/

/images/
/others/
research/

# PDF files in root directory only
/*.pdf

# Word template files with Chinese names
skills/md2word/assets/templates/剑桥颐华律所模板.docx

# Word files in root directory only
/*.docx
/*.doc

# Python cache files
**/__pycache__/
**/*.pyc
**/*.pyo
**/venv/
**/.venv/

# Database files
**/*.db
**/*.sqlite
**/*.sqlite3

# Playwright browser data
**/.playwright-data/
.playwright-mcp/

# Log files
**/logs/
*.log

# Claude Code internal
.claude/scheduled_tasks.lock

# Private skills - symlinked external repository
/private-skills

# Local-only Fachuan research package
/fachuan/

# Skill downloads/output directories
skills/*/downloads/
skills/*/output/*

# Search history (user-specific usage data)
**/search_history.json

# ClawHub sync records (contains internal IDs)
skills/clawhub-sync/config/sync-records.yaml
skills/clawhub-sync/config/sync-allowlist.yaml

# Case directories created by court-sms skill (contain real case data)
# Pattern: （YYYY）XXXX号 .../
（*号/
（*号 */

# Task state files (auto-generated at runtime)
skills/zhihe-legal-research/assets/pending.json
skills/zhihe-legal-research/assets/completed.json
skills/zhihe-legal-research/assets/notified.json

# Memory update files
UPDATE_MEMORY.md

# Litigation analysis lite (local-only development)
skills/litigation-analysis-lite/

# Skill manager registry (contains local paths and machine-specific state)
skills/skill-manager/assets/skill-registry.json

# 元典 API archive (query results to save credits)
skills/yuandian-law-search/archive/

# Claude Code 内置 skills（由系统管理，无需跟踪）
skills/task-implement
skills/task-alignment
skills/ultra-research

# Custom skills（用户自定义符号链接）
custom-skills
